{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "UPLOADTHING_TOKEN",
    "CORS_ORIGIN",
    "DATABASE_URL",
    "DIRECT_URL",
    "GOOGLE_LOCATION_API_KEY",
    "CLERK_SECRET_KEY",
    "CLERK_SIGNING_SECRET"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "UPLOADTHING_TOKEN",
        "CORS_ORIGIN",
        "DATABASE_URL",
        "DIRECT_URL",
        "GOOGLE_LOCATION_API_KEY",
        "CLERK_SECRET_KEY",
        "CLERK_SIGNING_SECRET"
      ],
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    }
  }
}
